# Dead Today — environment variables
# Copy to .env.local and fill in. .env.local is gitignored.

# Anthropic API key for /api/chat (Claude proxy).
# When ABSENT, /api/chat runs in STUB mode (canned streamed text) so the
# UI is fully testable without a key. Set this to flip chat to live Claude.
ANTHROPIC_API_KEY=

# Claude model for concert chat (Data Architecture §2.3).
ANTHROPIC_MODEL=claude-sonnet-4-20250514
